{
	"compilerOptions": {
		"module": "CommonJS",
		"moduleResolution": "Node",
		"target": "ES2022",

		"baseUrl": "./src",
		"paths": {
            "@/*": ["*"]
        },

		"rootDir": "src",
		"outDir": "dist",

		"strict": true,
		"esModuleInterop": true,
		"types" : ["node"],
		"skipLibCheck": true
	},
	"include": ["src"]
}
